## Core
APP_TITLE=Apps
DATABASE_URL=postgresql://user:password@localhost:5432/apps
NODE_ENV=development
NUXT_PUBLIC_SITE_URL=http://localhost:2080

## Auth (JWT) — generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

## Email (Mailgun)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
# Optional: Use 'api.eu.mailgun.net' for EU region
MAILGUN_HOST=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Apps

## S3 Storage
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
# Optional — only needed for public files
S3_PUBLIC_BASE_URL=

## OAuth layer — generate with: openssl rand -base64 32
OAUTH_CONSENT_COOKIE_SECRET=
OAUTH_ALLOW_DCR=true

## MCP layer
MCP_SERVER_NAME=Apps
MCP_SERVER_VERSION=1.0.0

## Secret encryption (used by layers that store encrypted credentials via core's secret-crypto)
## Generate with: openssl rand -hex 32   (must be exactly 64 hex chars / 32 bytes)
NUXT_SECRET_ENCRYPTION_KEY=

## Per-layer local override — point an individual layer at a sibling checkout on disk.
## Format: NUXTINATOR_<ID>_PATH (id uppercased, hyphens/slashes become underscores).
## Without an override, layers resolve as `@nuxtinator/<id>` from node_modules/
## (workspace symlink in dev; npm tarball or git URL when consumed externally).
# NUXTINATOR_CORE_PATH=../../my-core-checkout
# NUXTINATOR_MESSAGES_PATH=../../scratch/messages-experiment
# NUXTINATOR_EMAIL_MAILGUN_PATH=../../email-fork

## Testing — see scripts/setup-test-db.sh to provision the test DB + roles.
## TEST_DATABASE_URL connects as host_admin (BYPASSRLS) — used by migrations,
## test setup, and the tenancy adminDb.
## TEST_APP_DATABASE_URL connects as app_user (RLS-enforced) — what the Nuxt
## server's `db` client uses during test runs.
TEST_DATABASE_URL=postgresql://host_admin:test@localhost:5432/go_saas_test
TEST_APP_DATABASE_URL=postgresql://app_user:test@localhost:5432/go_saas_test
## Playwright test server port (must differ from dev's 2080).
TEST_BASE_URL=http://localhost:2090
## MailHog HTTP API used by tests to read captured verification emails.
TEST_MAILHOG_URL=http://localhost:8025
