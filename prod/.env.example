## Core (required)
APP_TITLE=My App
## Database TLS auto-negotiates by default (postgres.js 'prefer': TLS when the
## server offers it, plaintext when it doesn't) — works as-is on local Postgres,
## a private-network Postgres/PgBouncer that speaks plaintext (Docker, Dokploy,
## Fly internal), and a managed Postgres that requires TLS. To force a posture,
## append ?sslmode=... to the URL (standard libpq: disable | require | verify-full).
## Use verify-full (with a CA the cert chains to) for real MITM protection.
DATABASE_URL=postgresql://user:password@localhost:5432/myapp
NODE_ENV=development
NUXT_PUBLIC_SITE_URL=http://localhost:2080

## Auth (JWT) — generate with: openssl rand -base64 32
JWT_SECRET=

## Secret encryption (used by layers that store encrypted credentials)
## Generate with: openssl rand -hex 32   (must be exactly 64 hex chars / 32 bytes)
NUXT_SECRET_ENCRYPTION_KEY=

## Tenancy (only if @nuxtinator/tenancy is included). Falls back to DATABASE_URL if unset.
APP_DATABASE_URL=
## Signing secret for tenancy invite/flow tokens — generate with: openssl rand -base64 32
NUXT_TENANT_FLOW_SECRET=

## Email (Mailgun) — only if @nuxtinator/email-mailgun is included
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Optional: 'api.eu.mailgun.net' for EU region
MAILGUN_HOST=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=My App

## OAuth (only if @nuxtinator/oauth is included) — generate with: openssl rand -base64 32
OAUTH_CONSENT_COOKIE_SECRET=
OAUTH_ALLOW_DCR=true

## MCP (only if @nuxtinator/mcp is included)
MCP_SERVER_NAME=My App
MCP_SERVER_VERSION=1.0.0

## S3 storage (only if a layer uploads — e.g. @nuxtinator/videos, @nuxtinator/messages attachments)
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Optional — dedicated public-read bucket for public uploads (bind a CDN custom
# domain to it). Falls back to S3_BUCKET_NAME if unset. Must be the same bucket
# that S3_PUBLIC_BASE_URL points at.
S3_PUBLIC_BUCKET_NAME=
# Optional — public read URL (the custom domain bound to the public bucket above).
# Required for public files.
S3_PUBLIC_BASE_URL=

## Feedback widget project id (only if @nuxtinator/feedback is included)
NUXT_PUBLIC_FEEDBACK_PROJECT_ID=

## Pin which ref of nuxtinator sync-layers fetches from (defaults to master).
## Set to a tag or SHA for production reproducibility, e.g. NUXTINATOR_REF=v1.0.0
# NUXTINATOR_REF=master

## Per-layer local override — point an individual layer at a sibling checkout on disk.
## Format: NUXTINATOR_<ID>_PATH (id uppercased, hyphens/slashes become underscores).
## Without an override, layers resolve through node_modules/@nuxtinator/<id>/ (the
## bun workspace symlink from _layers/<id>/ once `bun run setup` has run).
# NUXTINATOR_CORE_PATH=../../my-core-checkout
# NUXTINATOR_MESSAGES_PATH=../../scratch/messages-experiment
# NUXTINATOR_EMAIL_MAILGUN_PATH=../../email-fork
